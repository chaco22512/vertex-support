# Copy to .env and fill in. .env is git-ignored (Hard rule 1: secrets never committed).
# Server-side only (apps/api, scripts). Never expose service_role / Gemini / Resend / Slack to the browser.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
GEMINI_API_KEY=
SLACK_WEBHOOK_URL=
RESEND_API_KEY=
ADMIN_BASE_URL=http://localhost:5174

# Scripts / migrations only (NOT a Workers runtime var, NOT in parseEnv's required set).
# Postgres connection string for `supabase db push`. Use the Session pooler URI (port 5432).
SUPABASE_DB_URL=
